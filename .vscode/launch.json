{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run App (GUI)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/venv/Scripts/python.exe",
            "justMyCode": true
        },
        {
            "name": "Run CLI (single URL)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/cli.py",
            "args": [
                "--url", "https://example.com",
                "--output", "${workspaceFolder}/output.epub",
                "--title", "Test Book",
                "--author", "Test Author"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/venv/Scripts/python.exe",
            "justMyCode": true
        },
        {
            "name": "Run CLI (multi URL file)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/cli.py",
            "args": [
                "--multi", "${workspaceFolder}/urls.txt",
                "--output", "${workspaceFolder}/output.epub",
                "--title", "Test Book",
                "--author", "Test Author"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/venv/Scripts/python.exe",
            "justMyCode": true
        },
        {
            "name": "Run Build Script",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/build.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/venv/Scripts/python.exe",
            "justMyCode": true
        },
        {
            "name": "Run Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${workspaceFolder}/tests",
                "-v"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/venv/Scripts/python.exe",
            "justMyCode": false
        }
    ]
}
